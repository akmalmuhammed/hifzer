# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/.playwright-cli
/output/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/tmp
/.tmp
/.tmp-lighthouse/
/.lighthouse-hifzer-*.json
.next-dev.log
.next-dev.err.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel
.wrangler
workers/ai-gateway/.dev.vars
workers/ai-gateway/.dev.vars.*

# typescript
*.tsbuildinfo
next-env.d.ts

# local runtime data
/ha-bot/services/engine/data/*.db
/ha-bot/services/engine/data/*.db-shm
/ha-bot/services/engine/data/*.db-wal

# local Codex desktop worktrees
/.claude/worktrees/
