generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanBias {
  BALANCED
  RETENTION
  SPEED
}

enum SubscriptionPlan {
  FREE
  PAID
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  PAUSED
  CANCELED
}

enum SrsMode {
  NORMAL
  CONSOLIDATION
  CATCH_UP
}

enum MemorizationBand {
  ENCODING
  SABQI
  MANZIL
  MASTERED
}

enum GateType {
  WARMUP
  WEEKLY
  MONTHLY
}

enum GateOutcome {
  PASS
  FAIL
  SKIPPED
  REBALANCED
}

enum SessionStatus {
  OPEN
  COMPLETED
  ABANDONED
}

enum AttemptStage {
  WARMUP
  REVIEW
  NEW
  LINK
  WEEKLY_TEST
  LINK_REPAIR
}

enum ReviewPhase {
  STANDARD
  NEW_EXPOSE
  NEW_GUIDED
  NEW_BLIND
  WEEKLY_TEST
  LINK_REPAIR
}

enum SrsGrade {
  AGAIN
  HARD
  GOOD
  EASY
}

enum EmailDispatchStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
  DRY_RUN
}

enum BookmarkMutationType {
  CREATE
  UPDATE
  DELETE
  RESTORE
  CATEGORY_CREATE
  CATEGORY_UPDATE
  CATEGORY_DELETE
}

enum PrivateJournalEntryType {
  reflection
  dua
  repentance
  gratitude
  free
}

enum PrivateJournalDuaStatus {
  ongoing
  answered
  accepted_differently
}

enum QuranBrowseSource {
  READER_VIEW
  AUDIO_PLAY
  BACKFILL
}

enum CircleKind {
  HALAQAH
  FAMILY
}

enum CircleMemberRole {
  LEAD
  TEACHER
  PARENT
  STUDENT
}

enum CircleAttendanceStatus {
  PENDING
  ATTENDED
  MISSED
  EXCUSED
}

enum CircleOralCheckStatus {
  PENDING
  PASS
  REVIEW_NEEDED
  ABSENT
}

model UserProfile {
  id                    String   @id @default(cuid())
  clerkUserId           String   @unique
  timezone              String

  onboardingCompletedAt DateTime?

  dailyMinutes          Int
  practiceDays          Int[]
  reminderTimeLocal     String
  emailRemindersEnabled Boolean @default(true)
  emailUnsubscribedAt   DateTime?
  emailSuppressedAt     DateTime?
  planBias              PlanBias @default(BALANCED)

  activeSurahNumber     Int
  cursorAyahId          Int
  quranActiveSurahNumber Int @default(1)
  quranCursorAyahId     Int @default(1)
  quranTranslationId    String @default("en.sahih")
  quranShowDetails      Boolean @default(true)
  mode                  SrsMode  @default(NORMAL)
  hasTeacher            Boolean @default(false)

  avgReviewSeconds      Float @default(45)
  avgNewSeconds         Float @default(90)
  avgLinkSeconds        Float @default(35)

  reviewFloorPct        Int @default(70)
  consolidationThresholdPct Int @default(25)
  catchUpThresholdPct   Int @default(45)
  rebalanceUntil        DateTime?

  plan                  SubscriptionPlan   @default(FREE)
  paddleCustomerId      String?            @unique
  paddleSubscriptionId  String?            @unique
  subscriptionStatus    SubscriptionStatus?
  currentPeriodEnd      DateTime?

  darkMode              Boolean @default(false)
  themePreset           String  @default("standard")
  accentPreset          String  @default("teal")
  reciterId             String  @default("default")

  sessions              Session[]
  attempts              AyahAttempt[]
  reviews               AyahReview[]
  weakTransitions       WeakTransition[]
  reviewEvents          ReviewEvent[]
  gateRuns              QualityGateRun[]
  emailDispatches       EmailDispatch[]
  bookmarkCategories    BookmarkCategory[]
  bookmarks             Bookmark[]
  bookmarkEvents        BookmarkEvent[]
  quranFoundationAccount QuranFoundationAccount?
  privateJournalEntries PrivateJournalEntry[]
  quranBrowseEvents     QuranBrowseEvent[]
  customDuas           CustomDua[]
  duaDeckOrders        DuaDeckOrder[]
  ownedTeacherCircles   TeacherCircle[]           @relation("OwnedTeacherCircles")
  teacherCircleLinks    TeacherCircleMember[]     @relation("TeacherCircleLinkedUser")
  teacherCircleUpdates  TeacherCircleWeeklyCheck[] @relation("TeacherCircleUpdatedBy")

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PrivateJournalEntry {
  id                          String                   @id @default(cuid())
  userId                      String
  clientEntryId               String?
  type                        PrivateJournalEntryType
  title                       String?
  content                     String
  blocksJson                  Json?
  tags                        String[]                 @default([])
  pinned                      Boolean                  @default(false)
  linkedAyahId                Int?
  linkedSurahNumber           Int?
  linkedAyahNumber            Int?
  linkedSurahNameArabic       String?
  linkedSurahNameTransliteration String?
  linkedDuaJson               Json?
  duaStatus                   PrivateJournalDuaStatus?
  autoDeleteAt                DateTime?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientEntryId])
  @@index([userId, updatedAt])
  @@index([userId, autoDeleteAt])
}

model EmailDispatch {
  id                String              @id @default(cuid())
  userId            String
  templateKey       String
  localDate         String
  status            EmailDispatchStatus @default(PENDING)
  provider          String
  providerMessageId String?
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user              UserProfile         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, templateKey, localDate])
  @@index([localDate, status])
  @@index([userId, createdAt])
}

model BookmarkCategory {
  id         String      @id @default(cuid())
  userId     String
  name       String
  sortOrder  Int         @default(0)
  archivedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks  Bookmark[]

  @@index([userId, updatedAt])
  @@index([userId, archivedAt])
}

model Bookmark {
  id         String            @id @default(cuid())
  userId     String
  ayahId     Int
  surahNumber Int
  ayahNumber Int
  name       String
  note       String?
  categoryId String?
  isPinned   Boolean           @default(false)
  version    Int               @default(1)
  deletedAt  DateTime?
  quranFoundationBookmarkId String?
  quranFoundationSyncState String?
  quranFoundationLastSyncedAt DateTime?
  quranFoundationSyncError String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user       UserProfile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   BookmarkCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  events     BookmarkEvent[]

  @@index([userId, updatedAt])
  @@index([userId, deletedAt])
  @@index([userId, ayahId])
  @@index([categoryId])
  @@index([quranFoundationBookmarkId])
}

model QuranFoundationAccount {
  id                    String      @id @default(cuid())
  userId                String      @unique
  quranFoundationUserId String?
  displayName           String?
  email                 String?
  accessTokenCiphertext String
  refreshTokenCiphertext String?
  scopes                String[]    @default([])
  status                String      @default("connected")
  accessTokenExpiresAt  DateTime?
  lastMutationAt        String?
  lastSyncedAt          DateTime?
  lastError             String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
  @@index([quranFoundationUserId])
}

model BookmarkEvent {
  id               String               @id @default(cuid())
  userId           String
  bookmarkId       String?
  mutationType     BookmarkMutationType
  clientMutationId String
  payloadJson      Json?
  occurredAt       DateTime             @default(now())
  createdAt        DateTime             @default(now())

  user             UserProfile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmark         Bookmark?            @relation(fields: [bookmarkId], references: [id], onDelete: SetNull)

  @@unique([userId, clientMutationId])
  @@index([userId, occurredAt])
  @@index([bookmarkId, occurredAt])
}

model Session {
  id              String        @id @default(cuid())
  userId          String
  status          SessionStatus @default(OPEN)
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  localDate       String
  mode            SrsMode @default(NORMAL)
  reviewDebtMinutesAtStart Int @default(0)
  warmupPassed    Boolean?
  warmupRetryUsed Boolean @default(false)
  weeklyGateRequired Boolean @default(false)
  weeklyGatePassed Boolean?
  newUnlocked     Boolean @default(true)

  warmupAyahIds   Int[]
  reviewAyahIds   Int[]
  newStartAyahId  Int?
  newEndAyahId    Int?
  planJson        Json?

  user            UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts        AyahAttempt[]
  reviewEvents    ReviewEvent[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, startedAt])
  @@index([userId, localDate])
  @@unique([userId, startedAt])
}

model AyahAttempt {
  id        String       @id @default(cuid())
  userId    String
  sessionId String
  ayahId    Int
  stage     AttemptStage
  grade     SrsGrade
  createdAt DateTime     @default(now())

  user      UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, ayahId, createdAt])
  @@index([sessionId, createdAt])
}

model AyahReview {
  id           String    @id @default(cuid())
  userId       String
  ayahId       Int
  band         MemorizationBand @default(ENCODING)
  checkpointIndex Int @default(0)
  nextIntervalMinutes Int @default(1440)
  lastDurationSec Int?

  station      Int       @default(1)
  intervalDays Int       @default(1)
  easeFactor   Float     @default(2.5)
  repetitions  Int       @default(0)
  lapses       Int       @default(0)

  nextReviewAt DateTime
  lastReviewAt DateTime?
  lastGrade    SrsGrade?

  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ayahId])
  @@index([userId, nextReviewAt])
  @@index([userId, band, nextReviewAt])
}

model WeakTransition {
  id            String   @id @default(cuid())
  userId        String
  fromAyahId    Int
  toAyahId      Int

  attemptCount  Int      @default(0)
  failCount     Int      @default(0)
  successCount  Int      @default(0)
  successRateCached Float @default(0)

  lastOccurredAt DateTime
  nextRepairAt   DateTime?
  lastGrade      SrsGrade?
  resolvedAt    DateTime?

  user          UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fromAyahId, toAyahId])
  @@index([userId, nextRepairAt])
}

model ReviewEvent {
  id          String      @id @default(cuid())
  userId      String
  sessionId   String
  surahNumber Int
  ayahId      Int
  stage       AttemptStage
  phase       ReviewPhase @default(STANDARD)
  grade       SrsGrade?
  durationSec Int         @default(0)
  fromAyahId  Int?
  toAyahId    Int?
  createdAt   DateTime    @default(now())

  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, ayahId, createdAt])
  @@index([sessionId, createdAt])
}

model QualityGateRun {
  id          String      @id @default(cuid())
  userId      String
  gateType    GateType
  windowStart DateTime
  windowEnd   DateTime
  sampleSize  Int         @default(0)
  passRate    Float       @default(0)
  outcome     GateOutcome
  detailsJson Json?
  createdAt   DateTime    @default(now())

  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, gateType, createdAt])
  @@index([userId, windowEnd])
}

model QuranBrowseEvent {
  id         String            @id @default(cuid())
  userId     String
  ayahId     Int
  surahNumber Int
  localDate  String
  source     QuranBrowseSource
  firstSeenAt DateTime         @default(now())
  lastSeenAt DateTime          @default(now())

  user       UserProfile       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localDate, ayahId, source])
  @@index([userId, lastSeenAt])
  @@index([userId, ayahId, lastSeenAt])
  @@index([userId, localDate, source])
}

model CustomDua {
  id              String      @id @default(cuid())
  userId          String
  moduleId        String      @default("laylat-al-qadr")
  title           String
  arabic          String?
  transliteration String?
  translation     String
  note            String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, moduleId, updatedAt])
  @@index([userId, moduleId, createdAt])
}

model DuaDeckOrder {
  id        String      @id @default(cuid())
  userId    String
  moduleId  String      @default("laylat-al-qadr")
  itemKey   String
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId, itemKey])
  @@index([userId, moduleId, sortOrder, updatedAt])
}

model TeacherCircle {
  id          String      @id @default(cuid())
  ownerUserId String
  name        String
  kind        CircleKind
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  owner       UserProfile @relation("OwnedTeacherCircles", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members     TeacherCircleMember[]
  weeklyChecks TeacherCircleWeeklyCheck[]

  @@index([ownerUserId, updatedAt])
}

model TeacherCircleMember {
  id           String            @id @default(cuid())
  circleId     String
  linkedUserId String?
  displayName  String
  role         CircleMemberRole
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  circle       TeacherCircle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  linkedUser   UserProfile?      @relation("TeacherCircleLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  weeklyChecks TeacherCircleWeeklyCheck[]

  @@unique([circleId, displayName])
  @@index([circleId, role])
  @@index([linkedUserId])
}

model TeacherCircleWeeklyCheck {
  id               String                 @id @default(cuid())
  circleId         String
  memberId         String
  weekStartLocalDate String
  targetLabel      String
  targetStartAyahId Int?
  targetEndAyahId  Int?
  attendanceStatus CircleAttendanceStatus @default(PENDING)
  oralCheckStatus  CircleOralCheckStatus  @default(PENDING)
  teacherComment   String?
  parentComment    String?
  updatedByUserId  String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  circle           TeacherCircle          @relation(fields: [circleId], references: [id], onDelete: Cascade)
  member           TeacherCircleMember    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  updatedBy        UserProfile            @relation("TeacherCircleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Cascade)

  @@unique([memberId, weekStartLocalDate])
  @@index([circleId, weekStartLocalDate])
  @@index([updatedByUserId, updatedAt])
}
